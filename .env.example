# Kopyalayıp .env yapın; gerçek değerleri buraya yazmayın (git'e commit etmeyin).

# Telegram (server SSE taraması bildirimi, telegram_autopilot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenRouter (Streamlit AI asistanı, server /api/ai_chat)
OPENROUTER_API_KEY=

# İsteğe bağlı: GitHub Actions tetikleme (telegram_autopilot)
GITHUB_TOKEN=
